{
  "version": 1,
  "providers": {
    "mock_local": {
      "type": "mock",
      "behavior": "deterministic",
      "latencyMs": 0,
      "responseTemplate": "MOCK[{agentId}]: {prompt}",
      "models": [{ "id": "mock-1" }]
    },
    "anthropic_remote": {
      "type": "api",
      "family": "anthropic",
      "baseURL": "https://api.anthropic.com/v1",
      "apiKeyEnv": "ANTHROPIC_API_KEY",
      "models": [
        { "id": "claude-haiku-4-5", "defaults": { "temperature": 0.7, "maxOutputTokens": 1024 } },
        { "id": "claude-sonnet-4-5", "defaults": { "temperature": 0.7, "maxOutputTokens": 4096 } }
      ]
    },
    "claude_cli_local": {
      "type": "cli",
      "cliType": "claude",
      "command": "claude",
      "models": [{ "id": "claude-sonnet-4-5" }]
    }
  },
  "agents": [
    { "id": "mock_a", "provider": "mock_local", "model": "mock-1" },
    { "id": "mock_b", "provider": "mock_local", "model": "mock-1", "systemPrompt": "you are a haiku." },
    { "id": "haiku_test", "provider": "anthropic_remote", "model": "claude-haiku-4-5" },
    { "id": "claude_local", "provider": "claude_cli_local", "model": "claude-sonnet-4-5" }
  ]
}
